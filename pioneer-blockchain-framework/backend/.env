DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=6700
DB_NAME=landdb

# App
PORT=5000
NODE_ENV=development

# =====================================================
# JWT CONFIGURATION
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_REFRESH_EXPIRES_IN=7d


PRIVATE_KEY=0x4f3edf983ac636a65a842ce7c78d9aa706d3b113b37f12dbf0e1d2fa0f8a3d44

ADMIN_PRIVATE_KEY=0x4f3edf983ac636a65a842ce7c78d9aa706d3b113b37f12dbf0e1d2fa0f8a3d44

# =====================================================
# ENCRYPTION KEYS
# =====================================================
AES_SECRET_KEY=your-32-character-aes-secret-key-here-change-this
PRIVATE_KEY_ENCRYPTION_KEY=another-32-char-key-for-private-keys

# =====================================================
# EMAIL SERVICE (NodeMailer)
# =====================================================
# For Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@landrecords.gov.pk

# For SendGrid (Alternative)
# SENDGRID_API_KEY=your-sendgrid-api-key

# For Mailgun (Alternative)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-mailgun-domain

# =====================================================
# SECURITY SETTINGS
# =====================================================
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=25
OTP_EXPIRY_MINUTES=5
PASSWORD_RESET_EXPIRY_MINUTES=15

# =====================================================
# BLOCKCHAIN CONFIGURATION (for future use)
# =====================================================
BLOCKCHAIN_NETWORK=testnet
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=1337
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# ADMIN NOTIFICATIONS
# =====================================================
ADMIN_EMAIL=admin@landrecords.gov.pk
ADMIN_PHONE=+923001234567

# =====================================================
# FRONTEND URL (for email links)
# =====================================================
FRONTEND_URL=http://localhost:3000

# =====================================================
# SESSION CONFIGURATION
# =====================================================
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_TIMEOUT_HOURS=24

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log







# WEBSOCKET CONFIGURATION
SOCKET_PORT=5000
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# FILE UPLOAD CONFIGURATION
UPLOADS_PATH=./uploads/agreements
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,webp

# RATE LIMITING
MESSAGE_RATE_LIMIT=10
PRICE_OFFER_RATE_LIMIT=5
SCREENSHOT_UPLOAD_LIMIT=3

# SECURITY
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-key

# BLOCKCHAIN CONFIGURATION (your existing settings)
MINING_DIFFICULTY=4
BLOCK_REWARD=50

# OPTIONAL: CLOUD STORAGE (for production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_BUCKET_NAME=your-bucket-name
# AWS_REGION=us-east-1

# OPTIONAL: REDIS (for scaling Socket.IO across multiple servers)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =====================================================
# HYPERLEDGER FABRIC
# =====================================================
FABRIC_CONNECTION_PROFILE=./connection-plra.json
FABRIC_CHANNEL_NAME=landregistry
FABRIC_VOTING_CHAINCODE=voting
FABRIC_AGREEMENT_CHAINCODE=land-agreement
FABRIC_WALLET_PATH=./wallet
FABRIC_DISCOVERY_ENABLED=true
FABRIC_DISCOVERY_AS_LOCALHOST=true
FABRIC_AUTO_DETECT_WSL_HOST=true
# FABRIC_HOST_OVERRIDE=172.x.x.x

