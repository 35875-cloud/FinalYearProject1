# Server
NODE_ENV=development
PORT=5000
NODE_ID=LRO_NODE_1
NODE_CITY=Lahore

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=landdb
DB_USER=postgres
DB_PASSWORD=6700

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Fabric
FABRIC_ENABLED=true
FABRIC_NETWORK_CONFIG=./fabric/connection-profile.json
FABRIC_WALLET_PATH=./fabric/wallet
FABRIC_USER_ID=admin
FABRIC_CHANNEL_NAME=land-registry-channel
FABRIC_CHAINCODE_NAME=voting-chaincode
FABRIC_PEER_ENDPOINT=peer0.org1:7051
FABRIC_ORDERER_ENDPOINT=orderer:7050
HOST=0.0.0.0
